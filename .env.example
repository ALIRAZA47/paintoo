# Copy to .env.local and fill in values.

# ── auth ─────────────────────────────────────────────────────────────
AUTH_USERNAME=artist
AUTH_PASSWORD=changeme
# Used to sign session cookies — keep secret, must be at least 8 chars.
AUTH_SECRET=replace-me-with-a-long-random-string
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── database ─────────────────────────────────────────────────────────
# Local dev (default): if TURSO_DATABASE_URL is not set, the app uses a local
# SQLite file at ./data/paintoo.db via libsql's native bindings.
#
# Production (Vercel / hosted): point at a Turso DB.
#   1) Create a DB on Turso (`turso db create paintoo`).
#   2) Grab the URL: `turso db show paintoo --url`
#   3) Mint a token:  `turso db tokens create paintoo`
# TURSO_DATABASE_URL=libsql://paintoo-yourorg.turso.io
# TURSO_AUTH_TOKEN=ey...
